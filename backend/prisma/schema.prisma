generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  passwordHash String
  emailVerified     Boolean   @default(false)
  verificationToken String?
  otp          String?
  otpExpiry    DateTime?
  role         String?   @default("student")
  createdAt    DateTime? @default(now()) @db.Timestamp(6)
  deletedAt    DateTime?
  company      Company?
  student      Student?
  college      College?
}
model Student {
  id                    Int           @id @default(autoincrement())
  userId                Int?          @unique
  profileComplete       Boolean       @default(false)
  gridPublished         Boolean       @default(false)
  gridUpdatesThisMonth  Int           @default(0)
  gridLastUpdatedMonth  Int?
  legalFullName         String?
  photoUrl              String?
  dateOfBirth           String?
  gender                String?
  contactNumber         String?
  address               String?
  city                  String?
  state                 String?
  pincode               String?
  schoolName            String?
  schoolBoard           String?
  schoolPassingYear     String?
  schoolPercentage      String?
  twelfthSchoolName     String?
  twelfthBoard          String?
  twelfthPassingYear    String?
  twelfthPercentage     String?
  collegeName           String?
  degree                String?
  branch                String?
  collegePassingYear    String?
  collegeCGPA           String?
  pgCollegeName         String?
  pgDegree              String?
  pgBranch              String?
  pgPassingYear         String?
  pgCGPA                String?
  workStatus            String?
  currentCompany        String?
  jobTitle              String?
  workExperience        String?
  preferredJobType      String?
  preferredWorkLocation String?
  noticePeriod          String?
  expectedSalary        String?
  technicalSkills       String?
  softSkills            String?
  languagesKnown        String?
  certifications        String?
  toolsAndSoftware      String?
  skills                String?
  hobbies               String?
  pfAccountNumber       String?
  aadhaarNumber         String?
  panNumber             String?
  passportNumber        String?
  aadhaarVerified       Boolean       @default(false)
  digiLockerStatus      String?
  bio                   String?
  gridNumber            String?       @unique
  education             String?
  schoolCollege         String?
  user                  User?         @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  applications          Application[]
  roadmap               Roadmap?
  examAttempts    StudentExamAttempt[]
  verifiedSkills  VerifiedSkill[]
  courseProgress  CourseProgress[]
  collegeId       Int?
  college         College?  @relation(fields: [collegeId], references: [id], onDelete: NoAction)
  documents             Document[]
}
model Roadmap {
  id                    Int       @id @default(autoincrement())
  studentId             Int       @unique
  workStatus            String
  answers               String
  careerOptions         String
  selectedCareer        String?
  roadmapContent        String?
  regeneratesThisMonth  Int       @default(0)
  lastRegeneratedMonth  Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  student               Student   @relation(fields: [studentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
model Company {
  id          Int     @id @default(autoincrement())
  userId      Int?    @unique
  companyName String
  mcaStatus   String? @default("pending")
  description String?
  industry    String?
  companySize String?
  website     String?
  location    String?
  foundedYear String?
  linkedIn    String?
  twitter     String?
  logoUrl     String?
  user        User?   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  jobs        Job[]
}
model Job {
  id              Int           @id @default(autoincrement())
  companyId       Int?
  title           String
  description     String?
  salaryRange     String?
  requiredSkills  String?
  jobType         String?
  location        String?
  experienceLevel String?
  openings        Int?          @default(1)
  deadline        String?
  status          String?       @default("active")
  targetCollegeId Int?
  isDrive         Boolean?      @default(false)
  driveDate       String?
  driveMode       String?
  driveLocation   String?
  eligBranches    String?
  eligMinCGPA     String?
  eligBatchYear   String?
  allowBacklogs   Boolean?      @default(true)
  driveCompany    String?
  createdAt       DateTime?     @default(now()) @db.Timestamp(6)
  applications    Application[]
  company         Company?      @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
model Application {
  id        Int       @id @default(autoincrement())
  studentId Int?
  jobId     Int?
  status    String?   @default("applied")
  rejectionReason String?
  rejectionNote   String?
  feedbackAt      DateTime?
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  job       Job?      @relation(fields: [jobId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  student   Student?  @relation(fields: [studentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model SkillExam {
  id          Int       @id @default(autoincrement())
  skill       String    @unique
  level       String    @default("intermediate")
  questions   String
  createdAt   DateTime  @default(now())
}

model StudentExamAttempt {
  id            Int       @id @default(autoincrement())
  studentId     Int
  skill         String
  score         Int
  totalQuestions Int
  passed        Boolean   @default(false)
  attemptNumber Int       @default(1)
  nextRetryAt   DateTime?
  createdAt     DateTime  @default(now())
  student       Student   @relation(fields: [studentId], references: [id], onDelete: NoAction)
}

model VerifiedSkill {
  id          Int       @id @default(autoincrement())
  studentId   Int
  skill       String
  verifiedAt  DateTime  @default(now())
  expiresAt   DateTime
  student     Student   @relation(fields: [studentId], references: [id], onDelete: NoAction)
}

model CourseProgress {
  id          Int       @id @default(autoincrement())
  studentId   Int
  courseId    String
  status      String    @default("started")
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  student     Student   @relation(fields: [studentId], references: [id], onDelete: NoAction)
}

model College {
  id          Int       @id @default(autoincrement())
  userId      Int?      @unique
  collegeName String
  slug        String    @unique
  city        String?
  state       String?
  logoUrl     String?
  tpoName     String?
  tpoEmail    String?
  tpoPhone    String?
  collegeType String    @default("Degree")
  streams     String?
  careerFields String?
  vetted      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  user        User?     @relation(fields: [userId], references: [id], onDelete: NoAction)
  students    Student[]
}

model PendingRegistration {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("student")
  otp          String
  otpExpiry    DateTime
  createdAt    DateTime @default(now())
  extraData    String?
}

model BlacklistedToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  createdAt DateTime @default(now())
}

model Document {
  id           Int      @id @default(autoincrement())
  studentId    Int
  docType      String
  label        String?
  filePath     String
  fileName     String?
  fileSize     Int?
  mimeType     String?
  trustStatus  String   @default("self_uploaded")
  verifiedBy   String?
  verifiedById Int?
  verifiedAt   DateTime?
  createdAt    DateTime @default(now())
  student      Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
}

